{
  "name": "AgentHound",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.14-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "lts" },
    "ghcr.io/astral-sh/uv:0": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "uv sync --all-extras --dev && cd frontend && npm install -g pnpm && pnpm install",
  "forwardPorts": [3000, 8765],
  "portsAttributes": {
    "3000": { "label": "AgentHound UI" },
    "8765": { "label": "AgentHound API" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
